<script>
    function initFtsMap(elementId) {
        if (!window.L) return;
        const L = window.L;
        const lat = 49.3215235;
        const lon = 8.18986;
        const mapNode = document.getElementById(elementId);
        if (!mapNode) return;

        const map = L.map(elementId, { zoomControl: true, scrollWheelZoom: false }).setView([lat, lon], 15);
        L.tileLayer('https://{s}.basemaps.cartocdn.com/light_all/{z}/{x}/{y}{r}.png', {
            attribution: '&copy; OpenStreetMap-Mitwirkende &copy; CARTO',
            subdomains: 'abcd',
            maxZoom: 20
        }).addTo(map);

        const markerIcon = L.divIcon({
            html: '<span class="fts-marker" aria-hidden="true"></span>',
            className: '',
            iconSize: [22, 22],
            iconAnchor: [11, 22]
        });

        L.marker([lat, lon], { icon: markerIcon }).addTo(map).bindPopup('FTS GmbH');
    }

    function setBackgroundWithFallback(selector, localUrl, fallbackUrl) {
        const probe = new Image();
        probe.onload = () => {
            document.querySelectorAll(selector).forEach((el) => {
                el.style.backgroundImage = `url('${localUrl}')`;
            });
        };
        probe.onerror = () => {
            document.querySelectorAll(selector).forEach((el) => {
                el.style.backgroundImage = `url('${fallbackUrl}')`;
            });
        };
        probe.src = localUrl;
    }

    const parallaxLayers = document.querySelectorAll('.parallax-layer');
    const compactMotionQuery = window.matchMedia('(max-width: 1024px), (prefers-reduced-motion: reduce)');
    let currentMouseX = window.innerWidth / 2;
    let currentMouseY = window.innerHeight / 2;
    let targetMouseX = window.innerWidth / 2;
    let targetMouseY = window.innerHeight / 2;

    const canAnimateParallax = !window.matchMedia('(prefers-reduced-motion: reduce)').matches
        && window.matchMedia('(min-width: 1024px)').matches;

    if (canAnimateParallax) {
        document.addEventListener('mousemove', (e) => {
            targetMouseX = e.clientX;
            targetMouseY = e.clientY;
        });
    } else {
        parallaxLayers.forEach((layer) => {
            layer.style.transform = 'none';
        });
    }

    function animateParallax() {
        currentMouseX += (targetMouseX - currentMouseX) * 0.05;
        currentMouseY += (targetMouseY - currentMouseY) * 0.05;

        const scrollY = window.scrollY;
        const centerX = window.innerWidth / 2;
        const centerY = window.innerHeight / 2;
        const compactMotion = compactMotionQuery.matches;
        const xMultiplier = compactMotion ? 0.22 : 1;
        const yMultiplier = compactMotion ? 0.45 : 1;
        const scrollMultiplier = compactMotion ? 1.4 : 2.5;
        const scale = compactMotion ? 1.02 : 1.05;

        parallaxLayers.forEach((layer) => {
            const speed = parseFloat(layer.getAttribute('data-speed'));
            const xOffset = (currentMouseX - centerX) * speed * xMultiplier;
            const yOffset = (((currentMouseY - centerY) * speed) + (scrollY * speed * scrollMultiplier)) * yMultiplier;

            layer.style.transform = `scale(${scale}) translate3d(${xOffset}px, ${yOffset}px, 0)`;
        });

        requestAnimationFrame(animateParallax);
    }

    document.addEventListener('DOMContentLoaded', () => {
        initFtsMap('contactLocationMap');

        setBackgroundWithFallback('.layer-bg', '/res/BG_BG.webp', 'https://raw.githubusercontent.com/christianslw/FTS/refs/heads/main/res/BG_BG.jpg');
        setBackgroundWithFallback('.layer-fg', '/res/BG_FG.png', 'https://raw.githubusercontent.com/christianslw/FTS/refs/heads/main/res/BG_FG.png');

        if (canAnimateParallax) {
            animateParallax();
        }
    });
</script>
