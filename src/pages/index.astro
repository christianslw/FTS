        .mobile-quickstart { display: block; }
    }

    .parallax-layer {
        position: absolute;
        top: -5%;
        left: -5%;
        width: 110%;
        height: 110%;
        will-change: transform;
        transition: transform 0.1s cubic-bezier(0.25, 0.46, 0.45, 0.94);
    }
    .layer-bg {
        background-image: url('/res/BG_BG.webp');
        background-size: cover;
        background-position: center center;
        z-index: 1;
    }
    .layer-fg {
        background-image: url('/res/BG_FG.png');
        background-size: cover;
        background-position: center bottom;
        background-repeat: no-repeat;
        left: 20%;
        z-index: 3;
    }
    .layer-overlay {
        position: absolute;
        inset: 0;
        background: rgba(0, 0, 0, 0.4); 
        z-index: 2;
    }
    .layer-content {
        position: absolute;
        inset: 0;
        left: -10%;
        z-index: 4;
        display: flex;
        align-items: center;
    }

    .logo-marquee {
        position: relative;
        overflow: hidden;
        background-color: var(--color-mint-500);
        border-top: 1px solid rgba(255, 255, 255, 0.32);
        border-bottom: 1px solid rgba(0, 0, 0, 0.18);
    }
    .logo-track {
        display: grid;
        grid-template-columns: repeat(3, minmax(0, 1fr));
        gap: 0.9rem;
        width: 100%;
    }
    .logo-item {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        min-height: 72px;
        padding: 0.75rem 1rem;
    }
    .logo-item img {
        max-height: 44px;
        max-width: 100%;
        filter: brightness(0) invert(1);
        opacity: 0.96;
        mix-blend-mode: normal;
    }
    .logo-item img[alt="DFMG"] {
        filter: none;
