---
import Layout from '../layouts/Layout.astro';
---

<Layout title="FTS - Funkturmservice GmbH | Telekommunikationsinfrastruktur">
    <!-- Map Quick Start (Mobile) -->
    <section class="mobile-quickstart bg-flat-darker text-white border-b border-flat-darkgray mt-20">
        <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 pt-10 pb-10">
            <p class="font-mono text-mint-500 text-xs uppercase tracking-[0.2em] mb-3">Schnellzugriff</p>
            <h1 class="text-3xl font-bold leading-tight mb-4">FTS Funkturmservice</h1>
            <p class="text-flat-gray text-sm leading-relaxed mb-6">Stahlbau, Elektrotechnik und Steigwege fuer kritische Infrastruktur. Schnell erreichbar, bundesweit einsatzbereit.</p>
            <div class="grid grid-cols-1 gap-3 mb-6">
                <a href="tel:+4963279794027" class="border border-flat-darkgray p-4 bg-flat-black">
                    <p class="font-mono text-xs text-mint-500 uppercase tracking-widest mb-1">Telefon</p>
                    <p class="text-white font-semibold">06327 979 40 27</p>
                </a>
                <a href="mailto:info@funkturmservice.de" class="border border-flat-darkgray p-4 bg-flat-black">
                    <p class="font-mono text-xs text-mint-500 uppercase tracking-widest mb-1">E-Mail</p>
                    <p class="text-white font-semibold break-all">info@funkturmservice.de</p>
                </a>
            </div>
            <div class="flex flex-col gap-3">
                <a href="#kompetenzen" class="btn-primary px-5 py-3 text-center text-xs uppercase tracking-widest">Leistungen</a>
                <a href="#kontakt" class="border border-white/40 px-5 py-3 text-center text-xs uppercase tracking-widest">Kontakt</a>
            </div>
        </div>
    </section>

    <!-- Parallax Hero Section -->
    <section class="hero-container" id="hero">
        <div class="parallax-layer layer-bg" data-speed="-0.015"></div>
        <div class="layer-overlay"></div>
        <div class="absolute inset-0 z-[2] bg-mint-gradient pointer-events-none"></div>
        <div class="parallax-layer layer-fg" data-speed="0.04"></div>

        <div class="parallax-layer layer-content" data-speed="-0.01">
            <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 w-full mt-24">
                <div class="bg-transparent backdrop-blur-xl border border-white/10 p-8 md:p-12 max-w-2xl relative">
                    <div class="absolute top-0 left-0 w-2 h-full bg-mint-500"></div>
                    <h1 class="text-4xl sm:text-5xl lg:text-6xl font-bold text-white leading-tight mb-6 tracking-tight">
                        Präzision <br> in jeder Höhe.
                    </h1>
                    <p class="text-flat-gray text-base md:text-lg mb-10 leading-relaxed font-light">
                        Ihr branchenerfahrener Partner für Stahlbau, Elektrotechnik und Steigwege. Wir realisieren komplexe Projekte – bundesweit. <br>
                        Sicher und zuverlässig nach höchsten Industriestandards.
                    </p>
                    <div class="flex flex-col sm:flex-row gap-4 mb-8">
                        <a href="#kontakt" class="btn-primary px-8 py-4 text-center text-sm uppercase tracking-widest focus-outline">Projekt anfragen</a>
                        <a href="#kompetenzen" class="btn-secondary px-8 py-4 text-center text-sm uppercase tracking-widest focus-outline">Unsere Leistungen</a>
                    </div>
                </div>
            </div>
        </div>
        <div class="absolute bottom-8 left-1/2 -translate-x-1/2 z-20 flex flex-col items-center opacity-70">
            <span class="font-mono text-[10px] text-white uppercase tracking-[0.2em] mb-3">Scroll</span>
            <div class="w-px h-12 bg-gradient-to-b from-mint-500 to-transparent scroll-indicator"></div>
        </div>
    </section>

    <!-- Partner Logos -->
    <section id="referenzen" class="logo-marquee relative z-20">
        <div class="logo-track py-3" aria-label="Partner und Kunden Logos">
            <div class="logo-item"><img src="/res/partner/BR.svg" alt="BR" /></div>
            <div class="logo-item"><img src="/res/partner/DFMG.svg" alt="DFMG" /></div>
            <div class="logo-item"><img src="/res/partner/HR.svg" alt="HR" /></div>
            <div class="logo-item"><img src="/res/partner/SWR.svg" alt="SWR" /></div>
            <div class="logo-item"><img src="/res/partner/MB.svg" alt="MB" /></div>
        </div>
    </section>

    <!-- Stats -->
    <section class="bg-flat-darker border-b border-flat-darkgray relative z-20">
        <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
            <div class="grid grid-cols-2 md:grid-cols-4 divide-x divide-y md:divide-y-0 divide-flat-darkgray border-l border-r border-flat-darkgray">
                {[
                    { number: "10+", label: "Jahre Erfahrung" },
                    { number: "2.5K", label: "Projekte" },
                    { number: "100%", label: "SCC Zertifiziert" }
                ].map((stat, i) => (
                    <div class="p-6 md:p-8 flex flex-col justify-center">
                        <span class="font-mono text-mint-500 text-xs tracking-widest mb-2">[ 0{i + 1} ]</span>
                        <p class="text-3xl font-bold text-white mb-1">{stat.number}</p>
                        <p class="text-xs text-flat-gray uppercase tracking-widest font-mono">{stat.label}</p>
                    </div>
                ))}
                <div class="p-6 md:p-8 flex flex-col justify-center bg-mint-500 group transition-colors hover:bg-flat-black">
                    <span class="font-mono text-flat-black group-hover:text-mint-500 text-xs tracking-widest mb-2 transition-colors">[ 04 ]</span>
                    <p class="text-3xl font-bold text-flat-black group-hover:text-white mb-1 transition-colors">365</p>
                    <p class="text-xs text-flat-darker group-hover:text-mint-500 uppercase tracking-widest font-mono transition-colors">Tage Service</p>
                </div>
            </div>
        </div>
    </section>

    <!-- Services -->
    <section id="kompetenzen" class="py-24 bg-flat-light">
        <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
            <div class="mb-16 border-l-4 border-mint-500 pl-6">
                <p class="font-mono text-mint-600 text-xs font-bold uppercase tracking-[0.2em] mb-4">Matrix // Leistungsspektrum</p>
                <h2 class="text-4xl font-bold text-flat-black max-w-2xl leading-tight">Architektur und Sicherheit für kritische Infrastrukturen.</h2>
            </div>
            
            <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6 mb-12">
                <div class="metro-tile p-8 flex flex-col h-full group">
                    <div class="flex justify-between items-start mb-12">
                        <svg class="w-8 h-8 text-flat-darkgray group-hover:text-mint-500 transition-colors" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1.5"><path stroke-linecap="square" stroke-linejoin="miter" d="M8.228 9c.549-1.165 2.03-2 3.772-2 2.21 0 4 1.343 4 3 0 1.4-1.278 2.575-3.006 2.907-.542.104-.994.54-.994 1.093m0 3h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"></path></svg>
                        <span class="font-mono text-flat-gray group-hover:text-flat-darkgray text-xs">01</span>
                    </div>
                    <h3 class="text-xl font-bold text-flat-black mb-4">Antennen- & Funknetze</h3>
                    <p class="text-flat-darkgray text-sm leading-relaxed mb-6 flex-grow">
                        Umfassender Antennenbau für komplexe Telekommunikationssysteme. Wir realisieren Infrastrukturen für <strong>Mobilfunk</strong>, <strong>Richtfunk</strong> und <strong>Betriebsfunk</strong> nach modernsten Herstellervorgaben.
                    </p>
                </div>

                <div class="metro-tile p-8 flex flex-col h-full group">
                    <div class="flex justify-between items-start mb-12">
                        <svg class="w-8 h-8 text-flat-darkgray group-hover:text-mint-500 transition-colors" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1.5"><path stroke-linecap="square" stroke-linejoin="miter" d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4"></path></svg>
                        <span class="font-mono text-flat-gray group-hover:text-flat-darkgray text-xs">02</span>
                    </div>
                    <h3 class="text-xl font-bold text-flat-black mb-4">Stahlbau & Montage</h3>
                    <p class="text-flat-darkgray text-sm leading-relaxed mb-6 flex-grow">
                        Konstruktion und Errichtung massiver Tragwerke. Unser Portfolio umfasst den klassischen <strong>Metallbau/Stahlbau</strong>, professionellen <strong>Kabelzug</strong> sowie komplexe <strong>Industriemontagen</strong>.
                    </p>
                </div>
                
                <div class="metro-tile p-8 flex flex-col h-full group">
                    <div class="flex justify-between items-start mb-12">
                        <svg class="w-8 h-8 text-flat-darkgray group-hover:text-mint-500 transition-colors" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1.5"><path stroke-linecap="square" stroke-linejoin="miter" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"></path></svg>
                        <span class="font-mono text-flat-gray group-hover:text-flat-darkgray text-xs">03</span>
                    </div>
                    <h3 class="text-xl font-bold text-flat-black mb-4">Steig- & Sicherungstechnik</h3>
                    <p class="text-flat-darkgray text-sm leading-relaxed mb-6 flex-grow">
                        Wirksame <strong>Absturzsicherung</strong> an Industrie- und Funkanlagen. Installation und Wartung von <strong>Steigschutzanlagen</strong>, <strong>ortsfesten Leitern</strong> und normgerechten <strong>Anschlageinrichtungen</strong>.
                    </p>
                </div>

                <div class="metro-tile p-8 flex flex-col h-full group">
                    <div class="flex justify-between items-start mb-12">
                        <svg class="w-8 h-8 text-flat-darkgray group-hover:text-mint-500 transition-colors" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1.5"><path stroke-linecap="square" stroke-linejoin="miter" d="M13.828 10.172a4 4 0 00-5.656 0l-4 4a4 4 0 105.656 5.656l1.102-1.101m-.758-4.899a4 4 0 005.656 0l4-4a4 4 0 00-5.656-5.656l-1.1 1.1"></path></svg>
                        <span class="font-mono text-flat-gray group-hover:text-flat-darkgray text-xs">04</span>
                    </div>
                    <h3 class="text-xl font-bold text-flat-black mb-4">Höhenzugangstechnik</h3>
                    <p class="text-flat-darkgray text-sm leading-relaxed mb-6 flex-grow">
                        Professionelles <strong>Industrieklettern</strong> für schwer zugängliche Bereiche. Unsere zertifizierten Experten führen jegliche <strong>Höhenarbeit</strong> sicher, effizient und gerüstlos aus.
                    </p>
                </div>

                <div class="metro-tile p-8 flex flex-col h-full group">
                    <div class="flex justify-between items-start mb-12">
                        <svg class="w-8 h-8 text-flat-darkgray group-hover:text-mint-500 transition-colors" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1.5"><path stroke-linecap="square" stroke-linejoin="miter" d="M13 10V3L4 14h7v7l9-11h-7z"></path></svg>
                        <span class="font-mono text-flat-gray group-hover:text-flat-darkgray text-xs">05</span>
                    </div>
                    <h3 class="text-xl font-bold text-flat-black mb-4">Elektro- & Blitzschutz</h3>
                    <p class="text-flat-darkgray text-sm leading-relaxed mb-6 flex-grow">
                        Fachmännische <strong>Elektrotechnik</strong> von der Stromversorgung bis zur Unterverteilung, ergänzt durch präzise <strong>Blitzschutzmontagen</strong> zum Schutz wertvoller Infrastrukturen.
                    </p>
                </div>

                <div class="metro-tile p-8 flex flex-col h-full group">
                    <div class="flex justify-between items-start mb-12">
                        <svg class="w-8 h-8 text-flat-darkgray group-hover:text-mint-500 transition-colors" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1.5"><path stroke-linecap="square" stroke-linejoin="miter" d="M5.636 18.364a9 9 0 010-12.728m12.728 0a9 9 0 010 12.728m-9.9-2.829a5 5 0 010-7.07m7.072 0a5 5 0 010 7.07M12 12h.01"></path></svg>
                        <span class="font-mono text-flat-gray group-hover:text-flat-darkgray text-xs">06</span>
                    </div>
                    <h3 class="text-xl font-bold text-flat-black mb-4">Spezialanlagen</h3>
                    <p class="text-flat-darkgray text-sm leading-relaxed mb-6 flex-grow">
                        Integration und Wartung sicherheitskritischer Systeme an Turmbauwerken, inklusive <strong>Brandmeldeanlagen</strong> sowie normgerechter <strong>Flughindernisbefeuerungen</strong>.
                    </p>
                </div>
            </div>

            <div class="bg-flat-darker text-white border-t-4 border-mint-500 grid lg:grid-cols-2 shadow-xl">
                <div class="p-8 md:p-12 lg:p-16 flex flex-col justify-center border-b lg:border-b-0 lg:border-r border-flat-darkgray">
                    <h3 class="text-2xl font-bold mb-6 text-white leading-snug">Qualität trifft auf ein starkes Netzwerk.</h3>
                    <p class="text-flat-gray font-light leading-relaxed mb-6">Wir setzen bei all unseren Montagen, im Stahlbau und in der Elektrotechnik stets auf qualitativ hochwertiges Material und arbeiten eng mit unseren verlässlichen Lieferanten zusammen.</p>
                    <div class="bg-flat-black border border-flat-darkgray p-6">
                        <p class="text-sm text-flat-gray font-mono">
                            <span class="text-mint-500 font-bold block mb-2 uppercase tracking-widest">Sonderanfragen</span>
                            Sollte Ihr Anliegen in unserer Matrix nicht explizit aufgeführt sein, fragen Sie gerne nach. Entweder können wir Ihnen direkt weiterhelfen oder vermitteln Ihnen gerne eines unserer spezialisierten Partnerunternehmen.
                        </p>
                    </div>
                </div>

                <div class="p-8 md:p-12 lg:p-16">
                    <p class="font-mono text-mint-500 text-xs font-bold uppercase tracking-[0.2em] mb-8 border-b border-flat-darkgray pb-4">Index // Gesamtkatalog</p>
                    <div class="grid grid-cols-1 sm:grid-cols-2 gap-x-8 gap-y-4">
                        {['Absturzsicherung','Anschlageinrichtung','Antennenbau','Betriebsfunk','Blitzschutzmontagen','Brandmeldeanlagen','Elektrotechnik','Flughindernisbefeuerungen','Höhenarbeit','Industrieklettern','Industriemontagen','Kabelzug','Metallbau / Stahlbau','Mobilfunk','Ortsfeste Leitern','Richtfunk','Steigschutzanlagen / -wartung'].map((item) => (
                            <div class={`flex items-start gap-3 ${item === 'Steigschutzanlagen / -wartung' ? 'sm:col-span-2' : ''}`}>
                                <div class="w-1.5 h-1.5 bg-mint-500 mt-2 flex-shrink-0"></div>
                                <span class="text-sm font-light text-flat-gray">{item}</span>
                            </div>
                        ))}
                    </div>
                </div>
            </div>
        </div>
    </section>

    <!-- Company History -->
    <section id="unternehmen" class="border-t border-b border-flat-gray bg-flat-white">
        <div class="flex flex-col lg:flex-row">
            <div class="w-full lg:w-1/2 p-8 sm:p-12 lg:p-24 flex items-center">
                <div class="max-w-xl">
                    <p class="font-mono text-mint-600 text-xs font-bold uppercase tracking-[0.2em] mb-6">Historie & Wachstum</p>
                    <h2 class="text-3xl md:text-4xl font-bold text-flat-black mb-8 leading-snug">Raum für neue Herausforderungen.</h2>
                    <p class="text-flat-darkgray mb-10 leading-relaxed">
                        Die Funkturmservice GmbH ist ein junges, innovatives und aufstrebendes Unternehmen im Bereich Elektrotechnik und Metallbau. Genauso vielfältig wie die Vorhaben unserer Kunden, ist auch unsere Leistungspalette - so finden wir für jede Anforderung die passende Lösung.
                    </p>

                    <div class="border-l-2 border-mint-500 pl-6 space-y-8 relative mb-4">
                        <div class="relative group">
                            <div class="absolute -left-[29px] top-1 w-2.5 h-2.5 bg-flat-light border-2 border-mint-500 group-hover:bg-mint-500 transition-colors"></div>
                            <p class="font-mono text-xs text-mint-600 mb-1">Februar 2016</p>
                            <h4 class="font-bold text-flat-black">Gründung FTS GmbH</h4>
                            <p class="text-sm text-flat-darkgray mt-1">Firmensitz in Kirrweiler und Werkstatt/Lager in Pirmasens.</p>
                        </div>
                        <div class="relative group">
                            <div class="absolute -left-[29px] top-1 w-2.5 h-2.5 bg-flat-light border-2 border-mint-500 group-hover:bg-mint-500 transition-colors"></div>
                            <p class="font-mono text-xs text-mint-600 mb-1">2018</p>
                            <h4 class="font-bold text-flat-black">Zusammenlegung</h4>
                            <p class="text-sm text-flat-darkgray mt-1">Umzug nach Edenkoben. Büro, Werkstatt und Lager an einem zentralen Ort vereint, um steigenden Anforderungen gerecht zu werden.</p>
                        </div>
                        <div class="relative group">
                            <div class="absolute -left-[29px] top-1 w-2.5 h-2.5 bg-mint-500 border-2 border-mint-500 shadow-[0_0_10px_rgba(0,210,138,0.5)]"></div>
                            <p class="font-mono text-xs text-flat-black font-bold mb-1">Mai 2021</p>
                            <h4 class="font-bold text-flat-black">Eigenes Firmengebäude</h4>
                            <p class="text-sm text-flat-darkgray mt-1">Um für die Zukunft gerüstet zu sein und kontinuierliches Wachstum zu ermöglichen, erfolgte der Umzug in die eigenen Räumlichkeiten nach Lachen-Speyerdorf.</p>
                        </div>
                    </div>
                </div>
            </div>
            <div class="w-full lg:w-1/2 bg-flat-darker border-l border-flat-darkgray p-8 sm:p-12 lg:p-24 flex flex-col justify-center text-white relative overflow-hidden">
                <div class="relative z-10 border border-flat-darkgray bg-flat-black p-10 md:p-12 shadow-2xl">
                    <h3 class="text-2xl font-bold mb-4">Unser wertvollstes Kapital.</h3>
                    <p class="text-flat-gray font-light leading-relaxed mb-6">Die Basis für unseren Erfolg sind unsere verantwortungsbewussten, gut ausgebildeten und engagierten Mitarbeiter.</p>
                    <a href="/karriere" class="mt-8 inline-block btn-primary px-6 py-3 text-sm uppercase tracking-widest focus-outline w-full text-center group">Werde Teil des Teams</a>
                </div>
            </div>
        </div>
    </section>

    <!-- Contact Section -->
    <section id="kontakt" class="py-24 bg-flat-light">
        <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
            <div class="fts-map-card">
                <div class="p-5 border-b border-flat-gray bg-flat-light">
                    <p class="font-mono text-xs text-flat-darkgray uppercase tracking-widest">Unternehmensstandort</p>
                    <p class="text-sm mt-1">Anfahrt und Position unseres Hauptsitzes in Neustadt an der Weinstraße.</p>
                </div>
                <div id="contactLocationMap" class="fts-map" aria-label="Karte mit dem Unternehmensstandort"></div>
            </div>            
            <div class="grid lg:grid-cols-12 gap-0 border border-flat-gray bg-flat-white shadow-2xl">
                <!-- Info Column -->
                <div class="lg:col-span-5 bg-flat-darker text-white p-10 lg:p-16 flex flex-col justify-between">
                    <div>
                        <p class="font-mono text-mint-500 text-xs font-bold uppercase tracking-[0.2em] mb-6">
                            Kommunikation
                        </p>
                        <h2 class="text-3xl font-bold mb-6">Senden Sie uns Ihr Anliegen.</h2>
                        <p class="text-flat-gray text-sm leading-relaxed mb-12">
                            Ob projektbezogene Beratung, Anfragen oder Karriere-Interesse: Wir melden uns umgehend bei Ihnen zurück.
                        </p>

                        <div class="space-y-8 font-mono text-sm">
                            <div>
                                <p class="text-mint-500 mb-1 tracking-widest text-xs uppercase">Adresse</p>
                                <a href="https://www.google.com/maps/dir/?api=1&destination=Theodor-Heuss-Straße+79a,+67435+Neustadt+an+der+Weinstraße" target="_blank" rel="noopener noreferrer" class="text-white hover:text-mint-500 transition-colors block focus-outline" aria-label="Route in Google Maps öffnen">
                                    FTS GmbH<br>Theodor-Heuss-Straße 79a<br>67435 Neustadt an der Weinstraße
                                </a>
                            </div>
                            <div>
                                <p class="text-mint-500 mb-1 tracking-widest text-xs uppercase">Telefon</p>
                                <a href="tel:+4963279794027" class="text-white hover:text-mint-500 transition-colors block focus-outline">06327 979 40 27</a>
                            </div>
                            <div>
                                <p class="text-mint-500 mb-1 tracking-widest text-xs uppercase">Telefax</p>
                                <a href="tel:+4963279793827" class="text-white hover:text-mint-500 transition-colors block focus-outline">06327 979 38 27</a>
                            </div>
                            <div>
                                <p class="text-mint-500 mb-1 tracking-widest text-xs uppercase">E-Mail</p>
                                <a href="mailto:info@funkturmservice.de" class="text-white hover:text-mint-500 transition-colors block focus-outline">info@funkturmservice.de</a>
                            </div>
                            <div>
                                <p class="text-mint-500 mb-1 tracking-widest text-xs uppercase">Geschäftszeiten</p>
                                <p class="text-white">Montag bis Freitag<br>07:30 Uhr - 16:30 Uhr</p>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- Form Column -->
                <div class="lg:col-span-7 p-10 lg:p-16 relative">
                    <form id="contactForm" class="space-y-6" onsubmit="event.preventDefault(); document.getElementById('form-success').classList.remove('hidden'); this.style.display='none';">
                        <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                            <div>
                                <label class="block font-mono text-xs text-flat-darkgray uppercase tracking-widest mb-2">Vorname</label>
                                <input type="text" class="flat-input" required>
                            </div>
                            <div>
                                <label class="block font-mono text-xs text-flat-darkgray uppercase tracking-widest mb-2">Nachname</label>
                                <input type="text" class="flat-input" required>
                            </div>
                        </div>
                        <div>
                            <label class="block font-mono text-xs text-flat-darkgray uppercase tracking-widest mb-2">Firma / Organisation</label>
                            <input type="text" class="flat-input">
                        </div>
                        <div>
                            <label class="block font-mono text-xs text-flat-darkgray uppercase tracking-widest mb-2">Geschäftliche E-Mail</label>
                            <input type="email" class="flat-input" required>
                        </div>
                        <div>
                            <label class="block font-mono text-xs text-flat-darkgray uppercase tracking-widest mb-2">Betreff / Anliegen</label>
                            <select class="flat-input appearance-none">
                                <option disabled selected>Bitte wählen...</option>
                                <option>Ausschreibung / Projekt</option>
                                <option>Wartungsanfrage</option>
                                <option>Allgemeine Anfrage</option>
                            </select>
                        </div>
                        <div>
                            <label class="block font-mono text-xs text-flat-darkgray uppercase tracking-widest mb-2">Nachricht</label>
                            <textarea rows="4" class="flat-input resize-none" required></textarea>
                        </div>

                        <div class="pt-4">
                            <button type="submit" class="btn-primary w-full py-4 text-sm uppercase tracking-widest focus-outline">
                                Anfrage übermitteln
                            </button>
                        </div>
                    </form>

                    <div id="form-success" class="hidden h-full flex flex-col items-center justify-center text-center p-8 bg-mint-500 text-flat-black border border-flat-darkgray">
                        <svg class="w-16 h-16 mb-6" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1.5"><path stroke-linecap="square" stroke-linejoin="miter" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"></path></svg>
                        <h3 class="text-2xl font-bold mb-2">Vielen Dank!</h3>
                        <p class="font-mono text-sm tracking-wide">Ihre Anfrage wurde erfolgreich übermittelt. Wir melden uns in Kürze bei Ihnen.</p>
                        <button onclick="document.getElementById('form-success').classList.add('hidden'); document.getElementById('contactForm').style.display='block'; document.getElementById('contactForm').reset();" class="mt-8 border border-flat-black px-6 py-2 hover:bg-flat-black hover:text-mint-500 transition-colors font-mono uppercase text-xs tracking-widest">
                            Neue Anfrage
                        </button>
                    </div>
                </div>
            </div>
        </div>
    </section>
</Layout>

<style>
