---
const { id = 'contactLocationMap', lat = 49.3215235, lon = 8.18986 } = Astro.props;
---

<div id={id} class="fts-map" aria-label="Karte mit dem Unternehmensstandort" data-lat={lat} data-lon={lon}></div>

<style>
    * { z-index: 0; }
    .fts-map { width: 100%; min-height: 240px; height: 450px; }
    .fts-marker { display: inline-block; width: 22px; height: 22px; border-radius: 50%; background: radial-gradient(circle at 50% 30%, #fff, #fff 20%, transparent 21%), linear-gradient(#00d28a,#00a86b); box-shadow: 0 0 10px rgba(0,0,0,0.35); }
</style>

<script>
    (function () {
        const ftsMaps = window.__ftsMaps || (window.__ftsMaps = {});

        function cleanupMap(elementId) {
            const map = ftsMaps[elementId];
            if (map && typeof map.remove === 'function') {
                try {
                    map.remove();
                } catch (e) {
                    console.warn('Failed to remove Leaflet map:', e);
                }
            }
            delete ftsMaps[elementId];
        }

        function initFtsMap(elementId, lat, lon) {
            if (!window.L) return false;
            const L = window.L;
            const mapNode = document.getElementById(elementId);
            if (!mapNode) return true;

            cleanupMap(elementId);

            const map = L.map(elementId, { zoomControl: true, scrollWheelZoom: false }).setView([lat, lon], 15);
            L.tileLayer('https://{s}.basemaps.cartocdn.com/light_all/{z}/{x}/{y}{r}.png', {
                attribution: '&copy; OpenStreetMap-Mitwirkende &copy; CARTO',
                subdomains: 'abcd',
                maxZoom: 20
            }).addTo(map);

            const markerIcon = L.divIcon({
                html: '<span class="fts-marker" aria-hidden="true"></span>',
                className: '',
                iconSize: [22, 22],
                iconAnchor: [11, 22]
            });

            L.marker([lat, lon], { icon: markerIcon }).addTo(map).bindPopup('FTS GmbH');
            ftsMaps[elementId] = map;
            return true;
        }

        function findMapElement() {
            const scriptEl = document.currentScript || document.scripts[document.scripts.length - 1];
            let el = null;
            if (scriptEl && scriptEl.previousElementSibling && scriptEl.previousElementSibling.classList.contains('fts-map')) {
                el = scriptEl.previousElementSibling;
            } else {
                el = document.querySelector('.fts-map[data-lat][data-lon]');
            }
            return el;
        }

        function handleMapInit() {
            const el = findMapElement();
            if (!el) return;

            if (!el.id) {
                el.id = 'fts-map-' + Math.random().toString(36).slice(2, 9);
            }

            const lat = parseFloat(el.dataset.lat) || 49.3215235;
            const lon = parseFloat(el.dataset.lon) || 8.18986;

            function tryInit() {
                if (initFtsMap(el.id, lat, lon)) return;
                setTimeout(tryInit, 100);
            }

            tryInit();
        }

        function cleanupAllMaps() {
            Object.keys(ftsMaps).forEach(cleanupMap);
        }

        document.addEventListener('DOMContentLoaded', handleMapInit);
        document.addEventListener('astro:page-load', handleMapInit);
        document.addEventListener('astro:before-swap', cleanupAllMaps);
    })();
</script>
