---
// src/components/ContactForm.astro
---

<div class="form-container">
  <p class="form-notice">
    <span class="text-red">Hinweis:</span> Felder mit * sind Pflichtfelder und werden zur Bearbeitung Ihrer Anfrage benötigt.
  </p>

  <form class="fts-contact-form" action="/api/contact" method="POST" enctype="multipart/form-data">
    <div class="form-group">
      <label for="firma">Firma</label>
      <input type="text" id="firma" name="firma" />
    </div>

    <div class="form-group">
      <label for="ansprechpartner">Ansprechpartner*</label>
      <input type="text" id="ansprechpartner" name="ansprechpartner" required />
    </div>

    <div class="form-row">
      <div class="form-group">
        <label for="plz-ort">PLZ/Ort der Baustelle</label>
        <input type="text" id="plz-ort" name="plz-ort" />
      </div>
      <div class="form-group">
        <label for="strasse-nr">Straße/Nr. der Baustelle</label>
        <input type="text" id="strasse-nr" name="strasse-nr" />
      </div>
    </div>

    <div class="form-group">
      <label for="telefon">Telefon</label>
      <input type="tel" id="telefon" name="telefon" />
    </div>

    <div class="form-group">
      <label for="email">E-Mail*</label>
      <input type="email" id="email" name="email" required />
    </div>

    <div class="form-group">
      <label for="email-repeat">Wiederholung E-Mail*</label>
      <input type="email" id="email-repeat" name="email-repeat" required />
    </div>

    <div class="form-group">
      <label for="nachricht">Ihre Nachricht/Anfrage*</label>
      <textarea id="nachricht" name="nachricht" rows="4" required></textarea>
    </div>

    <div class="form-group">
      <label for="dateianhang">Max. 1 Dateianhang (jpg, zip)</label>
      <div class="file-input-wrapper">
        <input type="file" id="dateianhang" name="dateianhang" accept=".jpg,.jpeg,.zip" />
      </div>
    </div>

    <div class="form-group">
      <label>Hinweis zum Datenschutz</label>
      <div class="privacy-box">
        <p>Wir verwenden Ihre Daten ausschließlich gemäß unserer Datenschutzhinweise/-erklärung.</p>
        <p class="privacy-links">
          <a href="/datenschutz">Allgemeine DSGVO &gt;&gt;&gt;</a>
          <a href="/datenschutz#kontaktformular">Zu den DSGVO für Kontaktformulare &gt;&gt;&gt;</a>
        </p>
      </div>
    </div>

    <div class="checkbox-group">
      <input type="checkbox" id="zustimmen" name="zustimmen" required />
      <label for="zustimmen">Zustimmen</label>
    </div>

    <div class="form-submit">
      <button type="submit">Senden</button>
    </div>
  </form>
</div>

<style>
  .form-container {
    max-width: 900px;
    margin: 0 auto;
  }

  .form-notice {
    font-size: 0.95rem;
    margin-bottom: 2rem;
  }

  .text-red {
    color: var(--primary-color, #cc0000); 
    font-weight: bold;
  }

  .fts-contact-form {
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
  }

  .form-group {
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
  }

  .form-row {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1.5rem;
  }

  label {
    font-size: 0.95rem;
    font-weight: 500;
  }

  input[type="text"],
  input[type="email"],
  input[type="tel"],
  textarea {
    width: 100%;
    background-color: var(--bg-secondary, #e2e8f0); 
    border: var(--border-width, 0) solid var(--border-color, transparent);
    border-radius: var(--border-radius, 0);
    padding: 0.8rem;
    font-family: inherit;
    font-size: 1rem;
    box-sizing: border-box;
    color: var(--text-main, inherit);
  }

  input:focus, textarea:focus {
    outline: 2px solid var(--primary-color, #a0aec0);
  }

  .file-input-wrapper {
    background-color: var(--bg-secondary, #e2e8f0);
    padding: 0.5rem;
    border-radius: var(--border-radius, 0);
  }

  .privacy-box {
    background-color: var(--bg-secondary, #e2e8f0);
    padding: 1.25rem;
    font-size: 0.95rem;
    line-height: 1.5;
    border-radius: var(--border-radius, 0);
  }

  .privacy-box p {
    margin: 0 0 0.5rem 0;
  }

  .privacy-links {
    display: flex;
    gap: 1.5rem;
    margin-bottom: 0 !important;
  }

  .privacy-links a {
    color: var(--text-main, #000);
    text-decoration: none;
    font-weight: bold;
    transition: color 0.2s ease;
  }

  .privacy-links a:hover {
    color: var(--primary-color, #cc0000);
    text-decoration: underline;
  }

  .checkbox-group {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    margin-top: 0.5rem;
  }

  .checkbox-group input[type="checkbox"] {
    width: 1rem;
    height: 1rem;
    accent-color: var(--primary-color, #cc0000);
  }

  .form-submit {
    margin-top: 1rem;
  }

  .form-submit button {
    background-color: var(--primary-color, #333);
    color: var(--text-inverse, #fff);
    padding: 0.75rem 2rem;
    border: none;
    border-radius: var(--border-radius, 0);
    cursor: pointer;
    font-size: 1rem;
    font-weight: bold;
    transition: opacity 0.2s ease;
  }

  .form-submit button:hover {
    opacity: 0.8;
  }

  @media (max-width: 640px) {
    .form-row {
      grid-template-columns: 1fr;
      gap: 1.25rem;
    }
    .privacy-links {
      flex-direction: column;
      gap: 0.5rem;
    }
  }
</style>