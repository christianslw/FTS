            <!-- Desktop Links (Center) -->
            <div class="hidden lg:flex flex-none items-center justify-center space-x-6 xl:space-x-10">
                <a href="/#kompetenzen" class="nav-link nav-main-link nav-dynamic text-white font-semibold text-sm tracking-widest py-2 focus-outline">Leistungen</a>
                <a href="/#news" class="nav-link nav-main-link nav-dynamic text-white font-semibold text-sm tracking-widest py-2 focus-outline">Neuigkeiten</a>
                <a href="/#unternehmen" class="nav-link nav-main-link nav-dynamic text-white font-semibold text-sm tracking-widest py-2 focus-outline">Über uns</a>
                <a href="/#referenzen" class="nav-link nav-main-link nav-dynamic text-white font-semibold text-sm tracking-widest py-2 focus-outline">Referenzen</a>
                <a href="/karriere" class="nav-link nav-main-link nav-dynamic text-white font-semibold text-sm tracking-widest py-2 focus-outline relative group">
                    Karriere
                    <span class="absolute top-2 -right-3 w-1.5 h-1.5 bg-mint-500 animate-slow-pulse" aria-hidden="true"></span>
                </a>
            </div>

            <!-- Right Elements (Lang & Action) -->
            <div class="hidden md:flex flex-1 items-center justify-end space-x-4 xl:space-x-8">
                <div class="lang-switch flex items-center gap-2 border-l border-white/25 pl-4 xl:pl-6">
                    <a href="#" class="nav-dynamic text-white text-sm font-semibold tracking-widest uppercase focus-outline">DE</a>
                    <span class="nav-dynamic text-white/60 text-sm font-bold">/</span>
                    <a href="#" class="nav-dynamic text-white/70 hover:text-white text-sm font-semibold tracking-widest uppercase transition-colors focus-outline">EN</a>
                </div>
                {isKarriere ? (
                    <a href="/karriere#bewerbung" class="btn-primary w-[160px] h-[38px] flex items-center justify-center text-sm font-bold uppercase tracking-widest focus-outline shadow-lg shadow-mint-500/20">Jetzt Bewerben</a>
                ) : (
                    <a href="/#kontakt" class="btn-primary w-[140px] h-[38px] flex items-center justify-center text-sm font-bold uppercase tracking-widest focus-outline shadow-lg shadow-mint-500/20">Kontakt</a>
                )}
            </div>

            <!-- Mobile Menu Button -->
            <div class="md:hidden flex-1 flex justify-end">
                <button class="text-white focus-outline p-2" id="mobile-btn" aria-label="Menü">
                    <svg class="w-7 h-7" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="square" stroke-linejoin="miter" stroke-width="2" d="M4 6h16M4 12h16m-7 6h7"></path></svg>
                </button>
            </div>
        </div>
    </div>
    
    <!-- Mobile Menu Dropdown -->
    <div id="mobile-menu" class="hidden md:hidden bg-white border-t border-flat-gray absolute w-full left-0 top-20 shadow-xl">
        <div class="flex flex-col px-4 py-6 space-y-4">
            <a href="/#kompetenzen" class="text-flat-black text-sm uppercase tracking-widest pb-2 border-b border-flat-gray">Leistungen</a>
            <a href="/#news" class="text-flat-black text-sm uppercase tracking-widest pb-2 border-b border-flat-gray">Neuigkeiten</a>
            <a href="/#unternehmen" class="text-flat-black text-sm uppercase tracking-widest pb-2 border-b border-flat-gray">Unternehmen</a>
            <a href="/#referenzen" class="text-flat-black text-sm uppercase tracking-widest pb-2 border-b border-flat-gray">Referenzen</a>
            <a href="/karriere" class="text-flat-black text-sm uppercase tracking-widest pb-2 border-b border-flat-gray flex justify-between items-center relative">
                Karriere
                <span class="w-2 h-2 bg-mint-500 animate-slow-pulse"></span>
            </a>
            <a href="/impressum" class="text-flat-black text-sm uppercase tracking-widest pb-2 border-b border-flat-gray">Impressum</a>
            <div class="flex items-center gap-4 pb-2 border-b border-flat-gray">
                <a href="#" class="text-mint-500 text-sm font-bold uppercase tracking-widest focus-outline">DE</a>
                <a href="#" class="text-flat-darkgray hover:text-flat-black text-sm font-semibold uppercase tracking-widest transition-colors focus-outline">EN</a>
            </div>
            {isKarriere ? (
                <a href="/karriere#bewerbung" class="text-mint-500 text-sm uppercase tracking-widest font-bold">Jetzt Bewerben</a>
            ) : (
                <a href="/#kontakt" class="text-mint-500 text-sm uppercase tracking-widest font-bold">Kontakt</a>
            )}
        </div>
    </div>
</header>
<script>
    let activeScrollListener = null;

    function initNavigation() {
        const nav = document.getElementById('main-nav');
        const mobileBtn = document.getElementById('mobile-btn');
        const menu = document.getElementById('mobile-menu');

        if (!nav) return;

        // SEHR EFFIZIENT: Tauscht nur noch eine Klasse auf dem Eltern-Element!
        const checkScroll = () => {
            if (window.scrollY > 50) {
                nav.classList.add('nav-solid');
                nav.classList.remove('nav-transparent');
            } else {
                nav.classList.remove('nav-solid');
                nav.classList.add('nav-transparent');
            }
        };

        // 1. Sofort prüfen beim Laden
        checkScroll();

        // 2. Alten Listener wegschmeißen (wichtig für den Astro ClientRouter)
        if (activeScrollListener) {
            window.removeEventListener('scroll', activeScrollListener);
        }

        // 3. Neuen Listener setzen
        activeScrollListener = checkScroll;
        window.addEventListener('scroll', activeScrollListener);

        // 4. Mobile Menü Logik
        mobileBtn?.addEventListener('click', () => {
            menu?.classList.toggle('hidden');
        });

        document.querySelectorAll('#mobile-menu a').forEach(link => {
            link.addEventListener('click', () => {
                menu?.classList.add('hidden');
            });
        });
    }

    document.addEventListener('astro:page-load', initNavigation);
</script>