---
import SpeedInsights from "@vercel/speed-insights/astro";
import '../styles/theme.css';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { ClientRouter } from 'astro:transitions';
import ContactForm from '../components/ContactForm.astro';

interface Props {
  title: string;
  description?: string;
  isKarriere?: boolean;
}

const { 
  title, 
  description = "Professioneller Mobilfunkausbau, Stahlbau, Wartung und Planung für Telekommunikationsinfrastruktur.",
  isKarriere = false
} = Astro.props;
---
<!DOCTYPE html>
<html lang="de" class="scroll-smooth">
<head>
    <meta charset="UTF-8">
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
    <link rel="alternate icon" href="/favicon.png" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{title}</title>
    <ClientRouter />
    <meta name="description" content={description}>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&family=JetBrains+Mono:wght@400;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css" integrity="sha256-p4NxAoJBhIIN+hmNHrzRCf9tD/miZyoHS5obTRR9BMY=" crossorigin="">
    <slot name="head" />
</head>
<body>
    <Header isKarriere={isKarriere} />
    
    <main>
      <slot />
    </main>
    <Footer />

    <script is:inline src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js" integrity="sha256-20nQCchB9co0qIjJZRGuk2/Z9VM+kNiyxNV1lvTlZBo=" crossorigin=""></script>
    <SpeedInsights />
</body>
</html>